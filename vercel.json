{
  "rewrites": [
    { "source": "/((?!api/|.well-known/|privacidade|termos|exclusao-de-conta|push-logo).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
